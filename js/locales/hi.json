{
    "meta": {
        "title": "\u0906\u0924\u094d\u092e\u093e \u0915\u0940 \u0909\u092e\u094d\u0930 \u091f\u0947\u0938\u094d\u091f | DopaBrain",
        "description": "\u0905\u092a\u0928\u0940 \u0906\u0924\u094d\u092e\u093e \u0915\u0940 \u0905\u0938\u0932\u0940 \u0909\u092e\u094d\u0930 \u091c\u093e\u0928\u0947\u0902! 12 \u0917\u0939\u0930\u0947 \u0938\u0935\u093e\u0932\u094b\u0902 \u0915\u0947 \u091c\u0935\u093e\u092c \u0926\u0947\u0902\u0964"
    },
    "a11y": {
        "skip": "\u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u092a\u0930 \u091c\u093e\u090f\u0902"
    },
    "app": {
        "title": "\u0906\u0924\u094d\u092e\u093e \u0915\u0940 \u0909\u092e\u094d\u0930 \u091f\u0947\u0938\u094d\u091f",
        "subtitle": "\u0906\u092a\u0915\u0940 \u0906\u0924\u094d\u092e\u093e \u0915\u093f\u0924\u0928\u0940 \u092a\u0941\u0930\u093e\u0928\u0940 \u0939\u0948?",
        "description": "12 \u0917\u0939\u0930\u0947 \u0938\u0935\u093e\u0932\u094b\u0902 \u0915\u0947 \u091c\u0935\u093e\u092c \u0926\u0947\u0915\u0930 \u0905\u092a\u0928\u0940 \u0906\u0924\u094d\u092e\u093e \u0915\u0940 \u0905\u0938\u0932\u0940 \u0909\u092e\u094d\u0930 \u091c\u093e\u0928\u0947\u0902\u0964 \u0915\u094d\u092f\u093e \u0906\u092a \u090f\u0915 \u0928\u0908 \u0906\u0924\u094d\u092e\u093e \u0939\u0948\u0902 \u092f\u093e \u092a\u094d\u0930\u093e\u091a\u0940\u0928 \u0926\u093f\u0935\u094d\u092f \u0905\u0938\u094d\u0924\u093f\u0924\u094d\u0935?",
        "start": "\u092e\u0947\u0930\u0940 \u0906\u0924\u094d\u092e\u093e \u0915\u0940 \u0909\u092e\u094d\u0930 \u091c\u093e\u0928\u0947\u0902"
    },
    "quiz": {
        "progress": "{current} / {total}"
    },
    "questions": {
        "q1": {
            "text": "\u0928\u0908 \u091c\u0917\u0939 \u092e\u0947\u0902 \u0906\u092a\u0915\u094b \u0915\u094d\u092f\u093e \u0906\u0915\u0930\u094d\u0937\u093f\u0924 \u0915\u0930\u0924\u093e \u0939\u0948?",
            "a": "\u0909\u0924\u094d\u0938\u093e\u0939 \u0914\u0930 \u0938\u093e\u0939\u0938\u093f\u0915",
            "b": "\u0928\u090f \u0932\u094b\u0917\u094b\u0902 \u0938\u0947 \u092e\u093f\u0932\u0928\u093e \u0914\u0930 \u0918\u0941\u0932\u0928\u093e-\u092e\u093f\u0932\u0928\u093e",
            "c": "\u0938\u094d\u0925\u093e\u0928\u0940\u092f \u0938\u0902\u0938\u094d\u0915\u0943\u0924\u093f \u0915\u094b \u0917\u0939\u0930\u093e\u0908 \u0938\u0947 \u0938\u092e\u091d\u0928\u093e",
            "d": "\u092a\u0939\u0932\u0947 \u0915\u092d\u0940 \u0906 \u091a\u0941\u0915\u0947 \u0939\u094b\u0928\u0947 \u0915\u093e \u0905\u091c\u0940\u092c \u090f\u0939\u0938\u093e\u0938"
        },
        "q2": {
            "text": "\u0906\u092a \u0938\u0902\u0918\u0930\u094d\u0937 \u0915\u094b \u0915\u0948\u0938\u0947 \u0938\u0902\u092d\u093e\u0932\u0924\u0947 \u0939\u0948\u0902?",
            "a": "\u0932\u0921\u093c\u094b \u092f\u093e \u092d\u093e\u0917\u094b \u2014 \u0936\u0941\u0926\u094d\u0927 \u0938\u0939\u091c \u092a\u094d\u0930\u0935\u0943\u0924\u094d\u0924\u093f",
            "b": "\u0928\u093f\u092f\u092e\u094b\u0902 \u0915\u093e \u092a\u093e\u0932\u0928 \u0915\u0930\u0915\u0947 \u091c\u0940\u0924\u0928\u0947 \u0915\u0940 \u0915\u094b\u0936\u093f\u0936",
            "c": "\u0938\u092d\u0940 \u092a\u0915\u094d\u0937\u094b\u0902 \u092a\u0930 \u0935\u093f\u091a\u093e\u0930 \u0915\u0930\u0924\u0947 \u0939\u0941\u090f \u0938\u092e\u091d\u094c\u0924\u093e \u0916\u094b\u091c\u0928\u093e",
            "d": "\u091a\u0941\u092a\u091a\u093e\u092a \u0926\u0947\u0916\u0928\u093e, \u092f\u0939 \u091c\u093e\u0928\u0924\u0947 \u0939\u0941\u090f \u0915\u093f \u092f\u0939 \u0916\u0941\u0926 \u0938\u0941\u0932\u091d \u091c\u093e\u090f\u0917\u093e"
        },
        "q3": {
            "text": "\u091c\u0940\u0935\u0928 \u092e\u0947\u0902 \u0938\u092c\u0938\u0947 \u092e\u0939\u0924\u094d\u0935\u092a\u0942\u0930\u094d\u0923 \u0915\u094d\u092f\u093e \u0939\u0948?",
            "a": "\u092e\u091c\u093c\u093e \u0914\u0930 \u0928\u090f \u0905\u0928\u0941\u092d\u0935",
            "b": "\u0938\u092b\u0932 \u0915\u0930\u093f\u092f\u0930 \u092c\u0928\u093e\u0928\u093e",
            "c": "\u0917\u0939\u0930\u0947 \u0930\u093f\u0936\u094d\u0924\u0947 \u0914\u0930 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0935\u093f\u0915\u093e\u0938",
            "d": "\u0906\u0902\u0924\u0930\u093f\u0915 \u0936\u093e\u0902\u0924\u093f \u0914\u0930 \u092c\u094d\u0930\u0939\u094d\u092e\u093e\u0902\u0921 \u0915\u094b \u0938\u092e\u091d\u0928\u093e"
        },
        "q4": {
            "text": "\u090f\u0915 \u092c\u091a\u094d\u091a\u093e \u092a\u0942\u091b\u0924\u093e \u0939\u0948 '\u0939\u092e \u0915\u094d\u092f\u094b\u0902 \u092e\u094c\u091c\u0942\u0926 \u0939\u0948\u0902?'",
            "a": "\u092e\u091c\u093c\u0947 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f!",
            "b": "\u0905\u092a\u0928\u0947 \u0906\u092a \u0915\u094b \u0915\u0941\u091b \u092c\u0928\u093e\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f",
            "c": "\u0938\u0940\u0916\u0928\u0947 \u0914\u0930 \u092a\u094d\u0930\u0947\u092e \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f",
            "d": "\u092f\u0939\u0940 \u0924\u094b \u0938\u0941\u0902\u0926\u0930 \u0930\u0939\u0938\u094d\u092f \u0939\u0948, \u0939\u0948 \u0928\u093e?"
        },
        "q5": {
            "text": "\u0915\u094c\u0928 \u0938\u093e \u092f\u0941\u0917 \u0906\u092a\u0915\u094b \u0938\u092c\u0938\u0947 \u091c\u094d\u092f\u093e\u0926\u093e \u0906\u0915\u0930\u094d\u0937\u093f\u0924 \u0915\u0930\u0924\u093e \u0939\u0948?",
            "a": "\u092d\u0935\u093f\u0937\u094d\u092f \u2014 \u0924\u0915\u0928\u0940\u0915 \u0914\u0930 \u092a\u094d\u0930\u0917\u0924\u093f",
            "b": "\u0935\u0930\u094d\u0924\u092e\u093e\u0928 \u2014 \u0905\u092d\u0940 \u0915\u093e \u0905\u0927\u093f\u0915\u0924\u092e \u0932\u093e\u092d \u0909\u0920\u093e\u0928\u093e",
            "c": "\u092a\u0941\u0928\u0930\u094d\u091c\u093e\u0917\u0930\u0923 \u2014 \u0915\u0932\u093e \u0914\u0930 \u091c\u093e\u0917\u0943\u0924\u093f",
            "d": "\u092a\u094d\u0930\u093e\u091a\u0940\u0928 \u0938\u092d\u094d\u092f\u0924\u093e\u090f\u0901 \u2014 \u0915\u093e\u0932\u093e\u0924\u0940\u0924 \u091c\u094d\u091e\u093e\u0928"
        },
        "q6": {
            "text": "\u092e\u0943\u0924\u094d\u092f\u0941 \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u0906\u092a \u0915\u0948\u0938\u093e \u092e\u0939\u0938\u0942\u0938 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902?",
            "a": "\u092e\u0948\u0902 \u0907\u0938\u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u0928\u0939\u0940\u0902 \u0938\u094b\u091a\u0924\u093e",
            "b": "\u092f\u0939 \u092e\u0941\u091d\u0947 \u0914\u0930 \u0905\u0927\u093f\u0915 \u0939\u093e\u0938\u093f\u0932 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u094d\u0930\u0947\u0930\u093f\u0924 \u0915\u0930\u0924\u093e \u0939\u0948",
            "c": "\u092f\u0939 \u090f\u0915 \u0938\u094d\u0935\u093e\u092d\u093e\u0935\u093f\u0915 \u092a\u0930\u093f\u0935\u0930\u094d\u0924\u0928 \u0939\u0948",
            "d": "\u0918\u0930 \u0932\u094c\u091f\u0928\u0947 \u091c\u0948\u0938\u093e \u0932\u0917\u0924\u093e \u0939\u0948"
        },
        "q7": {
            "text": "\u0915\u094c\u0928 \u0938\u0940 \u0938\u0902\u0917\u0940\u0924 \u0906\u092a\u0915\u094b \u092a\u094d\u0930\u092d\u093e\u0935\u093f\u0924 \u0915\u0930\u0924\u0940 \u0939\u0948?",
            "a": "\u0924\u0947\u091c\u093c, \u090a\u0930\u094d\u091c\u093e\u0935\u093e\u0928 \u0917\u093e\u0928\u0947",
            "b": "\u0932\u094b\u0915\u092a\u094d\u0930\u093f\u092f \u0939\u093f\u091f \u0917\u093e\u0928\u0947 \u091c\u094b \u0938\u092c \u091c\u093e\u0928\u0924\u0947 \u0939\u0948\u0902",
            "c": "\u092d\u093e\u0935\u0928\u093e\u0924\u094d\u092e\u0915 \u0917\u0939\u0930\u093e\u0908 \u0935\u093e\u0932\u0940 \u091c\u091f\u093f\u0932 \u0930\u091a\u0928\u093e\u090f\u0901",
            "d": "\u092a\u094d\u0930\u093e\u091a\u0940\u0928 \u0935\u093e\u0926\u094d\u092f\u092f\u0902\u0924\u094d\u0930, \u092a\u094d\u0930\u0915\u0943\u0924\u093f \u0915\u0940 \u0927\u094d\u0935\u0928\u093f\u092f\u093e\u0901, \u092e\u094c\u0928"
        },
        "q8": {
            "text": "\u0928\u090f \u0935\u094d\u092f\u0915\u094d\u0924\u093f \u0938\u0947 \u092e\u093f\u0932\u0924\u0947 \u0938\u092e\u092f, \u0906\u092a \u0938\u092c\u0938\u0947 \u092a\u0939\u0932\u0947 \u0926\u0947\u0916\u0924\u0947 \u0939\u0948\u0902...",
            "a": "\u0935\u0947 \u0915\u093f\u0924\u0928\u0947 \u092e\u091c\u093c\u0947\u0926\u093e\u0930 \u0932\u0917\u0924\u0947 \u0939\u0948\u0902",
            "b": "\u0909\u0928\u0915\u093e \u0938\u093e\u092e\u093e\u091c\u093f\u0915 \u0926\u0930\u094d\u091c\u093e \u092f\u093e \u0926\u093f\u0916\u093e\u0935\u091f",
            "c": "\u0909\u0928\u0915\u0940 \u092d\u093e\u0935\u0928\u093e\u0924\u094d\u092e\u0915 \u090a\u0930\u094d\u091c\u093e \u0914\u0930 \u092a\u094d\u0930\u093e\u092e\u093e\u0923\u093f\u0915\u0924\u093e",
            "d": "\u0909\u0928\u0915\u0940 \u0906\u0901\u0916\u0947\u0902 \u2014 \u0906\u0924\u094d\u092e\u093e \u0915\u0940 \u0916\u093f\u0921\u093c\u0915\u0940"
        },
        "q9": {
            "text": "\u0906\u092a\u0915\u093e \u0906\u0926\u0930\u094d\u0936 \u0938\u092a\u094d\u0924\u093e\u0939\u093e\u0902\u0924 \u0915\u0948\u0938\u093e \u0926\u093f\u0916\u0924\u093e \u0939\u0948?",
            "a": "\u092a\u093e\u0930\u094d\u091f\u0940, \u0938\u093e\u0939\u0938\u093f\u0915, \u0938\u094d\u0935\u0924:\u0938\u094d\u092b\u0942\u0930\u094d\u0924 \u092f\u094b\u091c\u0928\u093e\u090f\u0901",
            "b": "\u0909\u0924\u094d\u092a\u093e\u0926\u0915 \u2014 \u0932\u0915\u094d\u0937\u094d\u092f, \u091c\u093f\u092e, \u0928\u0947\u091f\u0935\u0930\u094d\u0915\u093f\u0902\u0917",
            "c": "\u0915\u0930\u0940\u092c\u0940 \u0926\u094b\u0938\u094d\u0924\u094b\u0902 \u0915\u0947 \u0938\u093e\u0925 \u0917\u0941\u0923\u0935\u0924\u094d\u0924\u093e \u0938\u092e\u092f, \u091a\u093f\u0902\u0924\u0928",
            "d": "\u092a\u094d\u0930\u0915\u0943\u0924\u093f \u092e\u0947\u0902 \u090f\u0915\u093e\u0902\u0924, \u0927\u094d\u092f\u093e\u0928, \u0924\u093e\u0930\u094b\u0902 \u0915\u094b \u0926\u0947\u0916\u0928\u093e"
        },
        "q10": {
            "text": "\u0928\u093f\u092f\u092e\u094b\u0902 \u0914\u0930 \u0905\u0927\u093f\u0915\u093e\u0930 \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u0906\u092a \u0915\u0948\u0938\u093e \u092e\u0939\u0938\u0942\u0938 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902?",
            "a": "\u0928\u093f\u092f\u092e \u092c\u094b\u0930\u093f\u0902\u0917 \u0939\u0948\u0902, \u092e\u0948\u0902 \u0905\u092a\u0928\u0940 \u092e\u0930\u094d\u091c\u093c\u0940 \u0938\u0947 \u091c\u0940\u0924\u093e \u0939\u0942\u0901",
            "b": "\u0928\u093f\u092f\u092e \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e \u0914\u0930 \u0938\u092b\u0932\u0924\u093e \u092c\u0928\u093e\u0924\u0947 \u0939\u0948\u0902",
            "c": "\u092e\u0948\u0902 \u0905\u092a\u0928\u0940 \u0928\u0948\u0924\u093f\u0915 \u0926\u093f\u0936\u093e \u0915\u093e \u092a\u093e\u0932\u0928 \u0915\u0930\u0924\u093e \u0939\u0942\u0901",
            "d": "\u0928\u093f\u092f\u092e \u092e\u093e\u0928\u0935\u0940\u092f \u0928\u093f\u0930\u094d\u092e\u093e\u0923 \u0939\u0948\u0902; \u0938\u0924\u094d\u092f \u0906\u0902\u0924\u0930\u093f\u0915 \u0939\u0948"
        },
        "q11": {
            "text": "\u0906\u092a\u0928\u0947 \u090f\u0915 \u0938\u094d\u092a\u0937\u094d\u091f \u0938\u092a\u0928\u093e \u0926\u0947\u0916\u093e\u0964 \u0906\u092a \u0938\u094b\u091a\u0924\u0947 \u0939\u0948\u0902...",
            "a": "\u0905\u091c\u0940\u092c \u0925\u093e! \u0906\u0917\u0947 \u092c\u0922\u093c\u0924\u0947 \u0939\u0948\u0902",
            "b": "\u092e\u0947\u0930\u0947 \u0932\u0915\u094d\u0937\u094d\u092f\u094b\u0902 \u0915\u0947 \u0932\u093f\u090f \u0907\u0938\u0915\u093e \u0915\u094d\u092f\u093e \u092e\u0924\u0932\u092c \u0939\u0948?",
            "c": "\u092f\u0939 \u092e\u0947\u0930\u0940 \u0906\u0902\u0924\u0930\u093f\u0915 \u0926\u0941\u0928\u093f\u092f\u093e \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u0915\u0941\u091b \u0926\u093f\u0916\u093e \u0930\u0939\u093e \u0939\u0948",
            "d": "\u092e\u0947\u0930\u0940 \u0906\u0924\u094d\u092e\u093e \u0926\u0942\u0938\u0930\u0947 \u091c\u0940\u0935\u0928 \u092f\u093e\u0926 \u0915\u0930 \u0930\u0939\u0940 \u0939\u0948"
        },
        "q12": {
            "text": "\u0938\u092e\u092f \u0915\u0947 \u0938\u093e\u0925 \u0906\u092a\u0915\u093e \u0930\u093f\u0936\u094d\u0924\u093e \u0915\u0948\u0938\u093e \u0939\u0948?",
            "a": "YOLO \u2014 \u092a\u0932 \u0915\u094b \u091c\u0940\u0913",
            "b": "\u0938\u092e\u092f \u0939\u0940 \u092a\u0948\u0938\u093e \u0939\u0948 \u2014 \u0938\u092e\u091d\u0926\u093e\u0930\u0940 \u0938\u0947 \u0916\u0930\u094d\u091a \u0915\u0930\u094b",
            "c": "\u0938\u092e\u092f \u091a\u0915\u094d\u0930\u0940\u092f \u0939\u0948 \u2014 \u091c\u094b \u091c\u093e\u0924\u093e \u0939\u0948 \u0935\u094b \u0932\u094c\u091f\u0924\u093e \u0939\u0948",
            "d": "\u0938\u092e\u092f \u090f\u0915 \u092d\u094d\u0930\u092e \u0939\u0948 \u2014 \u0938\u092d\u0940 \u0915\u094d\u0937\u0923 \u090f\u0915 \u0938\u093e\u0925 \u092e\u094c\u091c\u0942\u0926 \u0939\u0948\u0902"
        }
    },
    "tiers": {
        "infant": {
            "name": "\u0936\u093f\u0936\u0941 \u0906\u0924\u094d\u092e\u093e",
