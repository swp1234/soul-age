        "title": "\uc601\ud63c \ub098\uc774 \ud14c\uc2a4\ud2b8",
        "subtitle": "\ub2f9\uc2e0\uc758 \uc601\ud63c\uc740 \uba87 \uc0b4\uc77c\uae4c\uc694?",
        "description": "12\uac00\uc9c0 \uae4a\uc740 \uc9c8\ubb38\uc5d0 \ub2f5\ud574 \uc601\ud63c\uc758 \uc9c4\uc815\ud55c \ub098\uc774\ub97c \uc54c\uc544\ubcf4\uc138\uc694. \uc0c8\ub85c\uc6b4 \uc601\ud63c\uc778\uc9c0, \uace0\ub300 \ucd08\uc6d4\uc801 \uc874\uc7ac\uc778\uc9c0 \ud655\uc778\ud574\ubcf4\uc138\uc694!",
        "start": "\uc601\ud63c \ub098\uc774 \uc54c\uc544\ubcf4\uae30"
    },
    "quiz": {
        "progress": "{current} / {total}"
    },
    "questions": {
        "q1": {
            "text": "\uc0c8\ub85c\uc6b4 \uc7a5\uc18c\uc5d0 \ub04c\ub9ac\ub294 \uc774\uc720\ub294?",
            "a": "\uc124\ub818\uacfc \ubaa8\ud5d8",
            "b": "\uc0c8\ub85c\uc6b4 \uc0ac\ub78c\ub4e4\uc744 \ub9cc\ub098\uace0 \uc5b4\uc6b8\ub9ac\ub294 \uac83",
            "c": "\ud604\uc9c0 \ubb38\ud654\ub97c \uae4a\uc774 \uc774\ud574\ud558\ub294 \uac83",
            "d": "\uc804\uc5d0 \uc640\ubcf8 \uc801 \uc788\ub294 \ubb18\ud55c \ub290\ub08c"
        },
        "q2": {
            "text": "\uac08\ub4f1\uc744 \uc5b4\ub5bb\uac8c \ub2e4\ub8e8\ub098\uc694?",
            "a": "\ud22c\uc7c1 \uc544\ub2c8\uba74 \ub3c4\ub9dd \u2014 \ubcf8\ub2a5\uc801\uc73c\ub85c",
            "b": "\uaddc\uce59\uc744 \ub530\ub974\uba70 \uc774\uae30\ub824\uace0 \ub178\ub825",
            "c": "\ubaa8\ub4e0 \uce21\uba74\uc744 \uace0\ub824\ud55c \ud0c0\ud611\uc810 \ubaa8\uc0c9",
            "d": "\uc870\uc6a9\ud788 \uad00\ucc30, \uc2a4\uc2a4\ub85c \ud574\uacb0\ub420 \uac83\uc744 \uc54c\uae30\uc5d0"
        },
        "q3": {
            "text": "\uc778\uc0dd\uc5d0\uc11c \uac00\uc7a5 \uc911\uc694\ud55c \uac83\uc740?",
            "a": "\uc7ac\ubbf8\uc640 \uc0c8\ub85c\uc6b4 \uacbd\ud5d8",
            "b": "\uc131\uacf5\uc801\uc778 \ucee4\ub9ac\uc5b4 \uc313\uae30",
            "c": "\uae4a\uc740 \uc778\uac04\uad00\uacc4\uc640 \uc790\uae30 \uc131\uc7a5",
            "d": "\ub0b4\uba74\uc758 \ud3c9\ud654\uc640 \uc6b0\uc8fc\uc5d0 \ub300\ud55c \uc774\ud574"
        },
        "q4": {
            "text": "\uc544\uc774\uac00 '\uc6b0\ub9ac\ub294 \uc65c \uc874\uc7ac\ud574\uc694?'\ub77c\uace0 \ubb3c\uc5b4\ubcf4\ub294\ub370...",
            "a": "\uc7ac\ubbf8\uc788\uac8c \ub180\ub824\uace0!",
            "b": "\uc2a4\uc2a4\ub85c \ubb34\uc5b8\uac00\ub97c \ub9cc\ub4e4\uae30 \uc704\ud574",
            "c": "\ubc30\uc6b0\uace0 \uc0ac\ub791\ud558\uae30 \uc704\ud574",
            "d": "\uadf8\uac8c \uc544\ub984\ub2e4\uc6b4 \ubbf8\uc2a4\ud130\ub9ac\uc9c0, \uadf8\ub807\uc9c0 \uc54a\ub2c8?"
        },
        "q5": {
            "text": "\uac00\uc7a5 \ub9e4\ub8cc\ub418\ub294 \uc2dc\ub300\ub294?",
            "a": "\ubbf8\ub798 \u2014 \uae30\uc220\uacfc \ubc1c\uc804",
            "b": "\ud604\uc7ac \u2014 \uc9c0\uae08\uc744 \ucd5c\ub300\ud55c \ud65c\uc6a9",
            "c": "\ub974\ub124\uc0c1\uc2a4 \u2014 \uc608\uc220\uacfc \uac01\uc131",
            "d": "\uace0\ub300 \ubb38\uba85 \u2014 \uc2dc\ub300\ub97c \ucd08\uc6d4\ud55c \uc9c0\ud61c"
        },
        "q6": {
            "text": "\uc8fd\uc74c\uc5d0 \ub300\ud574 \uc5b4\ub5bb\uac8c \uc0dd\uac01\ud558\ub098\uc694?",
            "a": "\uc0dd\uac01 \uc548 \ud574\ubcf4",
            "b": "\ub354 \ub9ce\uc774 \uc131\ucde8\ud558\ub3c4\ub85d \ub3d9\uae30\ubd80\uc5ec\ud574\uc90c",
            "c": "\uc790\uc5f0\uc2a4\ub7ec\uc6b4 \uc804\ud658\uc774\uc9c0",
            "d": "\uc9d1\uc73c\ub85c \ub3cc\uc544\uac00\ub294 \ub290\ub08c"
        },
        "q7": {
            "text": "\uc5b4\ub5a4 \uc74c\uc545\uc774 \ub9c8\uc74c\uc744 \uc6c0\uc9c1\uc774\ub098\uc694?",
            "a": "\uc2e0\ub098\uace0 \uc5d0\ub108\uc9c0 \ub118\uce58\ub294 \uc74c\uc545",
            "b": "\ubaa8\ub450\uac00 \uc544\ub294 \uc778\uae30 \ud788\ud2b8\uace1",
            "c": "\uac10\uc815\uc801 \uae4a\uc774\uac00 \uc788\ub294 \ubcf5\uc7a1\ud55c \uad6c\uc131",
            "d": "\uace0\ub300 \uc545\uae30, \uc790\uc5f0\uc758 \uc18c\ub9ac, \uadf8\ub9ac\uace0 \uc815\uc801"
        },
        "q8": {
            "text": "\uc0c8\ub85c\uc6b4 \uc0ac\ub78c\uc744 \ub9cc\ub0a0 \ub54c \uac00\uc7a5 \uba3c\uc800 \ub208\uc5d0 \ub744\ub294 \uac83\uc740?",
            "a": "\uc5bc\ub9c8\ub098 \uc7ac\ubbf8\uc788\ub294 \uc0ac\ub78c\uc778\uc9c0",
            "b": "\uc0ac\ud68c\uc801 \uc9c0\uc704\ub098 \uc678\ubaa8",
            "c": "\uac10\uc815\uc801 \uc5d0\ub108\uc9c0\uc640 \uc9c4\uc815\uc131",
            "d": "\ub208 \u2014 \uc601\ud63c\uc758 \ucc3d"
        },
        "q9": {
            "text": "\uc774\uc0c1\uc801\uc778 \uc8fc\ub9d0\uc740?",
            "a": "\ud30c\ud2f0, \ubaa8\ud5d8, \uc990\ud765\uc801 \uacc4\ud68d",
            "b": "\uc0dd\uc0b0\uc801\uc73c\ub85c \u2014 \ubaa9\ud45c, \uc6b4\ub3d9, \ub124\ud2b8\uc6cc\ud0b9",
            "c": "\uac00\uae4c\uc6b4 \uce5c\uad6c\ub4e4\uacfc \uc88b\uc740 \uc2dc\uac04, \uc131\ucc30",
            "d": "\uc790\uc5f0 \uc18d \uace0\ub3c5, \uba85\uc0c1, \ubcc4 \ubcf4\uae30"
        },
        "q10": {
            "text": "\uaddc\uce59\uacfc \uad8c\uc704\uc5d0 \ub300\ud574 \uc5b4\ub5bb\uac8c \uc0dd\uac01\ud558\ub098\uc694?",
            "a": "\uaddc\uce59\uc740 \uc9c0\ub8e8\ud574, \ud558\uace0 \uc2f6\uc740 \ub300\ub85c \ud574",
            "b": "\uaddc\uce59\uc774 \uc9c8\uc11c\uc640 \uc131\uacf5\uc744 \ub9cc\ub4e0\ub2e4",
            "c": "\ub098\ub9cc\uc758 \ub3c4\ub355\uc801 \ub098\uce68\ubc18\uc744 \ub530\ub978\ub2e4",
            "d": "\uaddc\uce59\uc740 \uc778\uac04\uc758 \uc0b0\ubb3c; \uc9c4\uc2e4\uc740 \ub0b4\uba74\uc5d0 \uc788\ub2e4"
        },
        "q11": {
            "text": "\uc0dd\uc0dd\ud55c \uafbf\uc744 \uafb8\uc5c8\ub2e4\uba74?",
            "a": "\uc774\uc0c1\ud588\ub124! \ub118\uc5b4\uac00\uc790",
            "b": "\ub0b4 \ubaa9\ud45c\uc5d0 \ubb34\uc2a8 \uc758\ubbf8\uac00 \uc788\uc744\uae4c?",
            "c": "\ub0b4 \ub0b4\uba74 \uc138\uacc4\uc5d0 \ub300\ud574 \ubb54\uac00\ub97c \ubcf4\uc5ec\uc8fc\ub294 \uac83",
            "d": "\uc601\ud63c\uc774 \ub2e4\ub978 \uc0dd\uc744 \uae30\uc5b5\ud558\uace0 \uc788\ub294 \uac83"
        },
        "q12": {
            "text": "\uc2dc\uac04\uacfc\uc758 \uad00\uacc4\ub294?",
            "a": "YOLO \u2014 \uc9c0\uae08 \uc774 \uc21c\uac04\uc744 \uc0b4\uc790",
            "b": "\uc2dc\uac04\uc740 \ub3c8 \u2014 \ud604\uba85\ud558\uac8c \uc4f0\uc790",
            "c": "\uc2dc\uac04\uc740 \uc21c\ud658\uc801 \u2014 \ubfcc\ub9b0 \ub300\ub85c \uac70\ub450\ub294 \ubc95",
            "d": "\uc2dc\uac04\uc740 \ud658\uc0c1 \u2014 \ubaa8\ub4e0 \uc21c\uac04\uc774 \ub3d9\uc2dc\uc5d0 \uc874\uc7ac\ud55c\ub2e4"
        }
    },
