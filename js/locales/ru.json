{
    "meta": {
        "title": "\u0422\u0435\u0441\u0442 \u0432\u043e\u0437\u0440\u0430\u0441\u0442\u0430 \u0434\u0443\u0448\u0438 | DopaBrain",
        "description": "\u0423\u0437\u043d\u0430\u0439\u0442\u0435 \u0438\u0441\u0442\u0438\u043d\u043d\u044b\u0439 \u0432\u043e\u0437\u0440\u0430\u0441\u0442 \u0432\u0430\u0448\u0435\u0439 \u0434\u0443\u0448\u0438! \u041e\u0442\u0432\u0435\u0442\u044c\u0442\u0435 \u043d\u0430 12 \u0433\u043b\u0443\u0431\u043e\u043a\u0438\u0445 \u0432\u043e\u043f\u0440\u043e\u0441\u043e\u0432."
    },
    "a11y": {
        "skip": "\u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u043a \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u044e"
    },
    "app": {
        "title": "\u0422\u0435\u0441\u0442 \u0432\u043e\u0437\u0440\u0430\u0441\u0442\u0430 \u0434\u0443\u0448\u0438",
        "subtitle": "\u0421\u043a\u043e\u043b\u044c\u043a\u043e \u043b\u0435\u0442 \u0432\u0430\u0448\u0435\u0439 \u0434\u0443\u0448\u0435?",
        "description": "\u041e\u0442\u0432\u0435\u0442\u044c\u0442\u0435 \u043d\u0430 12 \u0433\u043b\u0443\u0431\u043e\u043a\u0438\u0445 \u0432\u043e\u043f\u0440\u043e\u0441\u043e\u0432, \u0447\u0442\u043e\u0431\u044b \u0443\u0437\u043d\u0430\u0442\u044c \u0438\u0441\u0442\u0438\u043d\u043d\u044b\u0439 \u0432\u043e\u0437\u0440\u0430\u0441\u0442 \u0432\u0430\u0448\u0435\u0439 \u0434\u0443\u0448\u0438. \u0412\u044b \u043d\u043e\u0432\u0430\u044f \u0434\u0443\u0448\u0430 \u0438\u043b\u0438 \u0434\u0440\u0435\u0432\u043d\u0435\u0435 \u0442\u0440\u0430\u043d\u0441\u0446\u0435\u043d\u0434\u0435\u043d\u0442\u043d\u043e\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043e?",
        "start": "\u0423\u0437\u043d\u0430\u0442\u044c \u0432\u043e\u0437\u0440\u0430\u0441\u0442 \u0434\u0443\u0448\u0438"
    },
    "quiz": {
        "progress": "{current} / {total}"
    },
    "questions": {
        "q1": {
            "text": "\u0427\u0442\u043e \u043f\u0440\u0438\u0432\u043b\u0435\u043a\u0430\u0435\u0442 \u0432\u0430\u0441 \u0432 \u043d\u043e\u0432\u043e\u043c \u043c\u0435\u0441\u0442\u0435?",
            "a": "\u0412\u043e\u043b\u043d\u0435\u043d\u0438\u0435 \u0438 \u043f\u0440\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u044f",
            "b": "\u0417\u043d\u0430\u043a\u043e\u043c\u0441\u0442\u0432\u043e \u0441 \u043d\u043e\u0432\u044b\u043c\u0438 \u043b\u044e\u0434\u044c\u043c\u0438 \u0438 \u0430\u0434\u0430\u043f\u0442\u0430\u0446\u0438\u044f",
            "c": "\u0413\u043b\u0443\u0431\u043e\u043a\u043e\u0435 \u043f\u043e\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u043c\u0435\u0441\u0442\u043d\u043e\u0439 \u043a\u0443\u043b\u044c\u0442\u0443\u0440\u044b",
            "d": "\u0421\u0442\u0440\u0430\u043d\u043d\u043e\u0435 \u043e\u0449\u0443\u0449\u0435\u043d\u0438\u0435, \u0447\u0442\u043e \u0432\u044b \u0443\u0436\u0435 \u0431\u044b\u043b\u0438 \u0437\u0434\u0435\u0441\u044c"
        },
        "q2": {
            "text": "\u041a\u0430\u043a \u0432\u044b \u0441\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442\u0435\u0441\u044c \u0441 \u043a\u043e\u043d\u0444\u043b\u0438\u043a\u0442\u043e\u043c?",
            "a": "\u0411\u0435\u0439 \u0438\u043b\u0438 \u0431\u0435\u0433\u0438 \u2014 \u0447\u0438\u0441\u0442\u044b\u0439 \u0438\u043d\u0441\u0442\u0438\u043d\u043a\u0442",
            "b": "\u041f\u044b\u0442\u0430\u044e\u0441\u044c \u043f\u043e\u0431\u0435\u0434\u0438\u0442\u044c \u043f\u043e \u043f\u0440\u0430\u0432\u0438\u043b\u0430\u043c",
            "c": "\u0418\u0449\u0443 \u043a\u043e\u043c\u043f\u0440\u043e\u043c\u0438\u0441\u0441, \u0443\u0447\u0438\u0442\u044b\u0432\u0430\u044e\u0449\u0438\u0439 \u0432\u0441\u0435 \u0441\u0442\u043e\u0440\u043e\u043d\u044b",
            "d": "\u0422\u0438\u0445\u043e \u043d\u0430\u0431\u043b\u044e\u0434\u0430\u044e, \u0437\u043d\u0430\u044f, \u0447\u0442\u043e \u0432\u0441\u0451 \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u0442\u0441\u044f \u0441\u0430\u043c\u043e"
        },
        "q3": {
            "text": "\u0427\u0442\u043e \u0432\u0430\u0436\u043d\u0435\u0435 \u0432\u0441\u0435\u0433\u043e \u0432 \u0436\u0438\u0437\u043d\u0438?",
            "a": "\u0412\u0435\u0441\u0435\u043b\u044c\u0435 \u0438 \u043d\u043e\u0432\u044b\u0435 \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u044f",
            "b": "\u041f\u043e\u0441\u0442\u0440\u043e\u0435\u043d\u0438\u0435 \u0443\u0441\u043f\u0435\u0448\u043d\u043e\u0439 \u043a\u0430\u0440\u044c\u0435\u0440\u044b",
            "c": "\u0413\u043b\u0443\u0431\u043e\u043a\u0438\u0435 \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u044f \u0438 \u043b\u0438\u0447\u043d\u043e\u0441\u0442\u043d\u044b\u0439 \u0440\u043e\u0441\u0442",
            "d": "\u0412\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0439 \u043c\u0438\u0440 \u0438 \u043f\u043e\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u0432\u0441\u0435\u043b\u0435\u043d\u043d\u043e\u0439"
        },
        "q4": {
            "text": "\u0420\u0435\u0431\u0451\u043d\u043e\u043a \u0441\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0435\u0442: \u00ab\u041f\u043e\u0447\u0435\u043c\u0443 \u043c\u044b \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u043c?\u00bb",
            "a": "\u0427\u0442\u043e\u0431\u044b \u0432\u0435\u0441\u0435\u043b\u0438\u0442\u044c\u0441\u044f!",
            "b": "\u0427\u0442\u043e\u0431\u044b \u0434\u043e\u0431\u0438\u0442\u044c\u0441\u044f \u0447\u0435\u0433\u043e-\u0442\u043e",
            "c": "\u0427\u0442\u043e\u0431\u044b \u0443\u0447\u0438\u0442\u044c\u0441\u044f \u0438 \u043b\u044e\u0431\u0438\u0442\u044c",
            "d": "\u042d\u0442\u043e \u043f\u0440\u0435\u043a\u0440\u0430\u0441\u043d\u0430\u044f \u0442\u0430\u0439\u043d\u0430, \u043d\u0435 \u043f\u0440\u0430\u0432\u0434\u0430 \u043b\u0438?"
        },
        "q5": {
            "text": "\u041a\u0430\u043a\u0430\u044f \u044d\u043f\u043e\u0445\u0430 \u0432\u0430\u0441 \u0431\u043e\u043b\u044c\u0448\u0435 \u0432\u0441\u0435\u0433\u043e \u0437\u0430\u0432\u043e\u0440\u0430\u0436\u0438\u0432\u0430\u0435\u0442?",
            "a": "\u0411\u0443\u0434\u0443\u0449\u0435\u0435 \u2014 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438 \u0438 \u043f\u0440\u043e\u0433\u0440\u0435\u0441\u0441",
            "b": "\u041d\u0430\u0441\u0442\u043e\u044f\u0449\u0435\u0435 \u2014 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u043c\u043e\u043c\u0435\u043d\u0442",
            "c": "\u0420\u0435\u043d\u0435\u0441\u0441\u0430\u043d\u0441 \u2014 \u0438\u0441\u043a\u0443\u0441\u0441\u0442\u0432\u043e \u0438 \u043f\u0440\u043e\u0431\u0443\u0436\u0434\u0435\u043d\u0438\u0435",
            "d": "\u0414\u0440\u0435\u0432\u043d\u0438\u0435 \u0446\u0438\u0432\u0438\u043b\u0438\u0437\u0430\u0446\u0438\u0438 \u2014 \u0432\u0435\u0447\u043d\u0430\u044f \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c"
        },
        "q6": {
            "text": "\u041a\u0430\u043a \u0432\u044b \u043e\u0442\u043d\u043e\u0441\u0438\u0442\u0435\u0441\u044c \u043a \u0441\u043c\u0435\u0440\u0442\u0438?",
            "a": "\u042f \u043e\u0431 \u044d\u0442\u043e\u043c \u043d\u0435 \u0434\u0443\u043c\u0430\u044e",
            "b": "\u042d\u0442\u043e \u043c\u043e\u0442\u0438\u0432\u0438\u0440\u0443\u0435\u0442 \u0434\u043e\u0441\u0442\u0438\u0433\u0430\u0442\u044c \u0431\u043e\u043b\u044c\u0448\u0435\u0433\u043e",
            "c": "\u042d\u0442\u043e \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u043f\u0435\u0440\u0435\u0445\u043e\u0434",
            "d": "\u041a\u0430\u043a \u0431\u0443\u0434\u0442\u043e \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u044e\u0441\u044c \u0434\u043e\u043c\u043e\u0439"
        },
        "q7": {
            "text": "\u041a\u0430\u043a\u0430\u044f \u043c\u0443\u0437\u044b\u043a\u0430 \u0442\u0440\u043e\u0433\u0430\u0435\u0442 \u0432\u0430\u0441?",
            "a": "\u0411\u043e\u0434\u0440\u044b\u0435, \u044d\u043d\u0435\u0440\u0433\u0438\u0447\u043d\u044b\u0435 \u0445\u0438\u0442\u044b",
            "b": "\u041f\u043e\u043f\u0443\u043b\u044f\u0440\u043d\u044b\u0435 \u043f\u0435\u0441\u043d\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u0441\u0435 \u0437\u043d\u0430\u044e\u0442",
            "c": "\u0421\u043b\u043e\u0436\u043d\u044b\u0435 \u043a\u043e\u043c\u043f\u043e\u0437\u0438\u0446\u0438\u0438 \u0441 \u044d\u043c\u043e\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0439 \u0433\u043b\u0443\u0431\u0438\u043d\u043e\u0439",
            "d": "\u0414\u0440\u0435\u0432\u043d\u0438\u0435 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b, \u0437\u0432\u0443\u043a\u0438 \u043f\u0440\u0438\u0440\u043e\u0434\u044b, \u0442\u0438\u0448\u0438\u043d\u0430"
        },
        "q8": {
            "text": "\u041f\u0440\u0438 \u0432\u0441\u0442\u0440\u0435\u0447\u0435 \u0441 \u043d\u043e\u0432\u044b\u043c \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u043e\u043c \u0432\u044b \u0441\u043d\u0430\u0447\u0430\u043b\u0430 \u0437\u0430\u043c\u0435\u0447\u0430\u0435\u0442\u0435...",
            "a": "\u041d\u0430\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043e\u043d\u0438 \u0432\u0435\u0441\u0451\u043b\u044b\u0435",
            "b": "\u0418\u0445 \u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0439 \u0441\u0442\u0430\u0442\u0443\u0441 \u0438\u043b\u0438 \u0432\u043d\u0435\u0448\u043d\u043e\u0441\u0442\u044c",
            "c": "\u0418\u0445 \u044d\u043c\u043e\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u0443\u044e \u044d\u043d\u0435\u0440\u0433\u0438\u044e \u0438 \u0438\u0441\u043a\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u044c",
            "d": "\u0418\u0445 \u0433\u043b\u0430\u0437\u0430 \u2014 \u043e\u043a\u043d\u0430 \u0434\u0443\u0448\u0438"
        },
        "q9": {
            "text": "\u0412\u0430\u0448\u0438 \u0438\u0434\u0435\u0430\u043b\u044c\u043d\u044b\u0435 \u0432\u044b\u0445\u043e\u0434\u043d\u044b\u0435...",
            "a": "\u0412\u0435\u0447\u0435\u0440\u0438\u043d\u043a\u0430, \u043f\u0440\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u044f, \u0441\u043f\u043e\u043d\u0442\u0430\u043d\u043d\u044b\u0435 \u043f\u043b\u0430\u043d\u044b",
            "b": "\u041f\u0440\u043e\u0434\u0443\u043a\u0442\u0438\u0432\u043d\u043e \u2014 \u0446\u0435\u043b\u0438, \u0441\u043f\u043e\u0440\u0442, \u043d\u0435\u0442\u0432\u043e\u0440\u043a\u0438\u043d\u0433",
            "c": "\u041a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f \u0441 \u0431\u043b\u0438\u0437\u043a\u0438\u043c\u0438, \u0440\u0430\u0437\u043c\u044b\u0448\u043b\u0435\u043d\u0438\u044f",
            "d": "\u0423\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u0435 \u043d\u0430 \u043f\u0440\u0438\u0440\u043e\u0434\u0435, \u043c\u0435\u0434\u0438\u0442\u0430\u0446\u0438\u044f, \u0437\u0432\u0451\u0437\u0434\u044b"
        },
        "q10": {
            "text": "\u041a\u0430\u043a \u0432\u044b \u043e\u0442\u043d\u043e\u0441\u0438\u0442\u0435\u0441\u044c \u043a \u043f\u0440\u0430\u0432\u0438\u043b\u0430\u043c \u0438 \u0432\u043b\u0430\u0441\u0442\u0438?",
            "a": "\u041f\u0440\u0430\u0432\u0438\u043b\u0430 \u0441\u043a\u0443\u0447\u043d\u044b, \u044f \u0434\u0435\u043b\u0430\u044e \u0447\u0442\u043e \u0445\u043e\u0447\u0443",
            "b": "\u041f\u0440\u0430\u0432\u0438\u043b\u0430 \u0441\u043e\u0437\u0434\u0430\u044e\u0442 \u043f\u043e\u0440\u044f\u0434\u043e\u043a \u0438 \u0443\u0441\u043f\u0435\u0445",
            "c": "\u042f \u0441\u043b\u0435\u0434\u0443\u044e \u0441\u0432\u043e\u0435\u043c\u0443 \u043c\u043e\u0440\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u043a\u043e\u043c\u043f\u0430\u0441\u0443",
            "d": "\u041f\u0440\u0430\u0432\u0438\u043b\u0430 \u2014 \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u0438\u0435 \u043a\u043e\u043d\u0441\u0442\u0440\u0443\u043a\u0446\u0438\u0438; \u0438\u0441\u0442\u0438\u043d\u0430 \u0432\u043d\u0443\u0442\u0440\u0438"
        },
        "q11": {
            "text": "\u0412\u0430\u043c \u043f\u0440\u0438\u0441\u043d\u0438\u043b\u0441\u044f \u044f\u0440\u043a\u0438\u0439 \u0441\u043e\u043d. \u0412\u044b \u0434\u0443\u043c\u0430\u0435\u0442\u0435...",
            "a": "\u0421\u0442\u0440\u0430\u043d\u043d\u043e! \u0418\u0434\u0451\u043c \u0434\u0430\u043b\u044c\u0448\u0435",
            "b": "\u0418\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u043e, \u0447\u0442\u043e \u044d\u0442\u043e \u0437\u043d\u0430\u0447\u0438\u0442 \u0434\u043b\u044f \u043c\u043e\u0438\u0445 \u0446\u0435\u043b\u0435\u0439",
            "c": "\u042d\u0442\u043e \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u0447\u0442\u043e-\u0442\u043e \u043e \u043c\u043e\u0451\u043c \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435\u043c \u043c\u0438\u0440\u0435",
            "d": "\u041c\u043e\u044f \u0434\u0443\u0448\u0430 \u0432\u0441\u043f\u043e\u043c\u0438\u043d\u0430\u0435\u0442 \u0434\u0440\u0443\u0433\u0438\u0435 \u0436\u0438\u0437\u043d\u0438"
        },
        "q12": {
            "text": "\u041a\u0430\u043a\u043e\u0432\u044b \u0432\u0430\u0448\u0438 \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u044f \u0441\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0435\u043c?",
            "a": "YOLO \u2014 \u0436\u0438\u0432\u0438 \u043c\u043e\u043c\u0435\u043d\u0442\u043e\u043c",
            "b": "\u0412\u0440\u0435\u043c\u044f \u2014 \u0434\u0435\u043d\u044c\u0433\u0438, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439 \u043c\u0443\u0434\u0440\u043e",
