    "questions": {
        "q1": {
            "text": "\u662f\u4ec0\u4e48\u5438\u5f15\u4f60\u53bb\u4e00\u4e2a\u65b0\u5730\u65b9\uff1f",
            "a": "\u5174\u594b\u548c\u5192\u9669",
            "b": "\u8ba4\u8bc6\u65b0\u4eba\u5e76\u878d\u5165\u5176\u4e2d",
            "c": "\u6df1\u5165\u4e86\u89e3\u5f53\u5730\u6587\u5316",
            "d": "\u4e00\u79cd\u66fe\u7ecf\u6765\u8fc7\u7684\u5947\u5999\u611f\u89c9"
        },
        "q2": {
            "text": "\u4f60\u5982\u4f55\u5904\u7406\u51b2\u7a81\uff1f",
            "a": "\u6218\u6216\u9003\u2014\u2014\u7eaf\u7cb9\u672c\u80fd",
            "b": "\u6309\u89c4\u5219\u52aa\u529b\u53d6\u80dc",
            "c": "\u5bfb\u6c42\u517c\u987e\u5404\u65b9\u7684\u59a5\u534f",
            "d": "\u9759\u9759\u89c2\u5bdf\uff0c\u77e5\u9053\u5b83\u4f1a\u81ea\u884c\u89e3\u51b3"
        },
        "q3": {
            "text": "\u751f\u6d3b\u4e2d\u6700\u91cd\u8981\u7684\u662f\u4ec0\u4e48\uff1f",
            "a": "\u5feb\u4e50\u548c\u65b0\u4f53\u9a8c",
            "b": "\u5efa\u7acb\u6210\u529f\u7684\u4e8b\u4e1a",
            "c": "\u6df1\u5c42\u5173\u7cfb\u548c\u4e2a\u4eba\u6210\u957f",
            "d": "\u5185\u5fc3\u5e73\u9759\u548c\u7406\u89e3\u5b87\u5b99"
        },
        "q4": {
            "text": "\u5b69\u5b50\u95ee\u201c\u6211\u4eec\u4e3a\u4ec0\u4e48\u5b58\u5728\uff1f\u201d",
            "a": "\u4e3a\u4e86\u5feb\u4e50\uff01",
            "b": "\u4e3a\u4e86\u6210\u5c31\u81ea\u5df1",
            "c": "\u4e3a\u4e86\u5b66\u4e60\u548c\u7231",
            "d": "\u8fd9\u5c31\u662f\u7f8e\u4e3d\u7684\u5965\u79d8\uff0c\u4e0d\u662f\u5417\uff1f"
        },
        "q5": {
            "text": "\u54ea\u4e2a\u65f6\u4ee3\u6700\u8ba9\u4f60\u7740\u8ff7\uff1f",
            "a": "\u672a\u6765\u2014\u2014\u79d1\u6280\u548c\u8fdb\u6b65",
            "b": "\u73b0\u5728\u2014\u2014\u5145\u5206\u5229\u7528\u5f53\u4e0b",
            "c": "\u6587\u827a\u590d\u5174\u2014\u2014\u827a\u672f\u548c\u89c9\u9192",
            "d": "\u53e4\u4ee3\u6587\u660e\u2014\u2014\u6c38\u6052\u7684\u667a\u6167"
        },
        "q6": {
            "text": "\u4f60\u5982\u4f55\u770b\u5f85\u6b7b\u4ea1\uff1f",
            "a": "\u6211\u4e0d\u60f3\u8fd9\u4e2a",
            "b": "\u5b83\u6fc0\u52b1\u6211\u53d6\u5f97\u66f4\u591a\u6210\u5c31",
            "c": "\u8fd9\u662f\u81ea\u7136\u7684\u8fc7\u6e21",
            "d": "\u611f\u89c9\u50cf\u56de\u5bb6"
        },
        "q7": {
            "text": "\u4ec0\u4e48\u6837\u7684\u97f3\u4e50\u6253\u52a8\u4f60\uff1f",
            "a": "\u6b22\u5feb\u3001\u5145\u6ee1\u6d3b\u529b\u7684\u6b4c\u66f2",
            "b": "\u4eba\u4eba\u90fd\u77e5\u9053\u7684\u6d41\u884c\u7ecf\u5178",
            "c": "\u5177\u6709\u60c5\u611f\u6df1\u5ea6\u7684\u590d\u6742\u4f5c\u54c1",
            "d": "\u53e4\u4ee3\u4e50\u5668\u3001\u81ea\u7136\u4e4b\u58f0\u3001\u5bc2\u9759"
        },
        "q8": {
            "text": "\u8ba4\u8bc6\u65b0\u4eba\u65f6\uff0c\u4f60\u9996\u5148\u6ce8\u610f\u5230...",
            "a": "\u4ed6\u4eec\u770b\u8d77\u6765\u591a\u6709\u8da3",
            "b": "\u4ed6\u4eec\u7684\u793e\u4f1a\u5730\u4f4d\u6216\u5916\u8868",
            "c": "\u4ed6\u4eec\u7684\u60c5\u611f\u80fd\u91cf\u548c\u771f\u5b9e\u6027",
            "d": "\u4ed6\u4eec\u7684\u773c\u775b\u2014\u2014\u7075\u9b42\u4e4b\u7a97"
        },
        "q9": {
            "text": "\u4f60\u7406\u60f3\u7684\u5468\u672b\u662f...",
            "a": "\u6d3e\u5bf9\u3001\u5192\u9669\u3001\u968f\u6027\u8ba1\u5212",
            "b": "\u9ad8\u6548\u2014\u2014\u76ee\u6807\u3001\u5065\u8eab\u3001\u793e\u4ea4",
            "c": "\u4e0e\u597d\u53cb\u5171\u5ea6\u7f8e\u597d\u65f6\u5149\uff0c\u53cd\u601d",
            "d": "\u5728\u81ea\u7136\u4e2d\u72ec\u5904\u3001\u5192\u60f3\u3001\u89c2\u661f"
        },
        "q10": {
            "text": "\u4f60\u5982\u4f55\u770b\u5f85\u89c4\u5219\u548c\u6743\u5a01\uff1f",
            "a": "\u89c4\u5219\u65e0\u804a\uff0c\u6211\u884c\u6211\u7d20",
            "b": "\u89c4\u5219\u521b\u9020\u79e9\u5e8f\u548c\u6210\u529f",
            "c": "\u6211\u9075\u5faa\u81ea\u5df1\u7684\u9053\u5fb7\u7f57\u76d8",
            "d": "\u89c4\u5219\u662f\u4eba\u4e3a\u6784\u9020\uff1b\u771f\u7406\u5728\u5185\u5fc3"
        },
        "q11": {
            "text": "\u4f60\u505a\u4e86\u4e00\u4e2a\u751f\u52a8\u7684\u68a6\uff0c\u4f60\u89c9\u5f97...",
            "a": "\u771f\u5947\u602a\uff01\u7ee7\u7eed\u751f\u6d3b",
            "b": "\u6211\u60f3\u77e5\u9053\u5b83\u5bf9\u6211\u7684\u76ee\u6807\u610f\u5473\u4ec0\u4e48",
            "c": "\u5b83\u5728\u5411\u6211\u5c55\u793a\u5185\u5fc3\u4e16\u754c\u7684\u4e00\u4e9b\u4e1c\u897f",
            "d": "\u6211\u7684\u7075\u9b42\u5728\u56de\u5fc6\u524d\u4e16"
        },
        "q12": {
            "text": "\u4f60\u4e0e\u65f6\u95f4\u7684\u5173\u7cfb\u662f\uff1f",
            "a": "YOLO\u2014\u2014\u6d3b\u5728\u5f53\u4e0b",
            "b": "\u65f6\u95f4\u5c31\u662f\u91d1\u94b1\u2014\u2014\u660e\u667a\u5229\u7528",
            "c": "\u65f6\u95f4\u662f\u5faa\u73af\u7684\u2014\u2014\u56e0\u679c\u5faa\u73af",
            "d": "\u65f6\u95f4\u662f\u5e7b\u89c9\u2014\u2014\u6240\u6709\u65f6\u523b\u540c\u65f6\u5b58\u5728"
