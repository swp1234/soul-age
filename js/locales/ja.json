        "q6": {
            "text": "\u6b7b\u306b\u3064\u3044\u3066\u3069\u3046\u611f\u3058\u307e\u3059\u304b\uff1f",
            "a": "\u8003\u3048\u305f\u3053\u3068\u306a\u3044",
            "b": "\u3082\u3063\u3068\u9054\u6210\u3057\u3088\u3046\u3068\u3044\u3046\u52d5\u6a5f\u306b\u306a\u308b",
