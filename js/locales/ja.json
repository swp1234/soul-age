    "questions": {
        "q1": {
            "text": "\u65b0\u3057\u3044\u5834\u6240\u306b\u60f9\u304b\u308c\u308b\u7406\u7531\u306f\uff1f",
            "a": "\u30ef\u30af\u30ef\u30af\u3068\u5192\u967a",
            "b": "\u65b0\u3057\u3044\u4eba\u3068\u51fa\u4f1a\u3044\u3001\u6eb6\u3051\u8fbc\u3080\u3053\u3068",
            "c": "\u73fe\u5730\u306e\u6587\u5316\u3092\u6df1\u304f\u7406\u89e3\u3059\u308b\u3053\u3068",
            "d": "\u4ee5\u524d\u6765\u305f\u3053\u3068\u304c\u3042\u308b\u3088\u3046\u306a\u4e0d\u601d\u8b70\u306a\u611f\u899a"
        },
        "q2": {
            "text": "\u5bfe\u7acb\u3092\u3069\u3046\u51e6\u7406\u3057\u307e\u3059\u304b\uff1f",
            "a": "\u6226\u3046\u304b\u9003\u3052\u308b\u304b\u2014\u672c\u80fd\u3067",
            "b": "\u30eb\u30fc\u30eb\u306b\u5f93\u3063\u3066\u52dd\u3068\u3046\u3068\u3059\u308b",
            "c": "\u3059\u3079\u3066\u306e\u5074\u9762\u3092\u8003\u616e\u3057\u305f\u59a5\u5354\u70b9\u3092\u63a2\u308b",
            "d": "\u9759\u304b\u306b\u89b3\u5bdf\u3001\u81ea\u7136\u306b\u89e3\u6c7a\u3059\u308b\u3068\u77e5\u3063\u3066\u3044\u308b"
        },
        "q3": {
            "text": "\u4eba\u751f\u3067\u6700\u3082\u5927\u5207\u306a\u3053\u3068\u306f\uff1f",
            "a": "\u697d\u3057\u307f\u3068\u65b0\u3057\u3044\u4f53\u9a13",
            "b": "\u6210\u529f\u3057\u305f\u30ad\u30e3\u30ea\u30a2\u3092\u7bc9\u304f\u3053\u3068",
            "c": "\u6df1\u3044\u4eba\u9593\u95a2\u4fc2\u3068\u500b\u4eba\u7684\u306a\u6210\u9577",
            "d": "\u5185\u306a\u308b\u5e73\u548c\u3068\u5b87\u5b99\u306e\u7406\u89e3"
        },
        "q4": {
            "text": "\u5b50\u4f9b\u304c\u300c\u306a\u305c\u79c1\u305f\u3061\u306f\u5b58\u5728\u3059\u308b\u306e\uff1f\u300d\u3068\u805e\u3044\u305f\u3089...",
            "a": "\u697d\u3057\u3080\u305f\u3081\uff01",
            "b": "\u4f55\u304b\u3092\u6210\u3057\u9042\u3052\u308b\u305f\u3081",
            "c": "\u5b66\u3073\u3001\u611b\u3059\u308b\u305f\u3081",
            "d": "\u305d\u308c\u304c\u7f8e\u3057\u3044\u8b0e\u3067\u3057\u3087\uff1f"
        },
        "q5": {
            "text": "\u6700\u3082\u9b45\u4e86\u3055\u308c\u308b\u6642\u4ee3\u306f\uff1f",
            "a": "\u672a\u6765\u2014\u30c6\u30af\u30ce\u30ed\u30b8\u30fc\u3068\u9032\u6b69",
            "b": "\u73fe\u5728\u2014\u4eca\u3092\u6700\u5927\u9650\u306b\u6d3b\u304b\u3059",
